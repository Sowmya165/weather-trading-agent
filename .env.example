# --- LLM provider (used by Hermes Agent) ---
OPENROUTER_API_KEY=sk-or-your api-key-here
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# --- Data sources ---
APIFY_API_TOKEN=your_api_key
# Open-Meteo needs no key (used as the free global weather source)
# Optional second global source for cross-validation
WEATHERAPI_KEY=your_weatherapi_key

# --- Polymarket ---
POLYMARKET_HOST=https://clob.polymarket.com
POLYMARKET_GAMMA_HOST=https://gamma-api.polymarket.com
# Paper trading only — never put a real funded private key here
POLYMARKET_PAPER_TRADER_DB=database/paper_trades.db

# --- Risk management ---
KELLY_FRACTION=0.25
MAX_POSITION_PCT_OF_BANKROLL=0.05
MAX_DAILY_LOSS_PCT=0.10
MAX_PORTFOLIO_EXPOSURE_PCT=0.40
STARTING_BANKROLL_USD=1000

# --- App ---
APP_ENV=development
LOG_LEVEL=INFO
DATABASE_URL=sqlite+aiosqlite:///database/app.db
API_HOST=0.0.0.0
API_PORT=8000
